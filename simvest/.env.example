# Copy to .env and fill in your keys. Never commit .env.
# Expo exposes EXPO_PUBLIC_* vars to the client bundle at build time.

# Finnhub — https://finnhub.io/register
EXPO_PUBLIC_FINNHUB_API_KEY=

# Alpha Vantage (optional) — https://www.alphavantage.co/support/#api-key
EXPO_PUBLIC_ALPHA_VANTAGE_API_KEY=

# Financial Modeling Prep (optional) — https://site.financialmodelingprep.com/developer/docs/
EXPO_PUBLIC_FMP_API_KEY=

# Groq — https://console.groq.com/keys
EXPO_PUBLIC_GROQ_API_KEY=

EXPO_PUBLIC_USE_REAL_NEWS=true

# Firebase client config — Firebase Console → Project settings
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
